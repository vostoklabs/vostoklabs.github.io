{
  "name": "vostok-labs-tools",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev:hub": "pnpm --filter hub dev",
    "build:hub": "pnpm --filter hub build",
    "dev:demo": "pnpm --filter kit-demo dev",
    "build:demo": "pnpm --filter kit-demo build",
    "dev:keychain": "pnpm --filter name-keychain dev",
    "build:keychain": "pnpm --filter name-keychain build",
    "dev:clicker": "pnpm --filter clicker-generator dev",
    "build:clicker": "pnpm --filter clicker-generator build",
    "dev:keycap": "pnpm --filter keycap-generator dev",
    "build:keycap": "pnpm --filter keycap-generator build",
    "typecheck": "pnpm -r --if-present typecheck"
  }
}
